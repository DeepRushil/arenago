# Environment Variables — Template
# Copy this file to .env and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your Apps → Web App

# ── Firebase Core ──────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Firebase Analytics (Google Analytics 4) ────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps → Measurement ID
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Firebase App Check — reCAPTCHA v3 ──────────────────────────────────────────
# Register a site at: https://www.google.com/recaptcha/admin
# Choose reCAPTCHA v3, add your domain, copy the Site Key here.
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
